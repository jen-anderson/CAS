generator client {
  provider = "prisma-client-js"
  
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model alias {
  alias_id        String            @id
  solvent_id      String
  alias_name      String
  alias_type      String?
  solvent         solvent           @relation(fields: [solvent_id], references: [solvent_id], onDelete: Cascade, onUpdate: Restrict)
  alias_reference alias_reference[]

  @@unique([solvent_id, alias_name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model alias_reference {
  alias_id     String
  reference_id String
  alias        alias     @relation(fields: [alias_id], references: [alias_id], onDelete: Cascade, onUpdate: NoAction)
  reference    reference @relation(fields: [reference_id], references: [reference_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([alias_id, reference_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model formula {
  formula_id                  String            @id
  canonical_name              String
  molecular_formula_hill      String?
  molecular_weight            Decimal?          @db.Decimal
  molar_vol                   Decimal?          @db.Decimal
  smiles                      String?
  inchi                       String?
  boiling_point               Decimal?          @db.Decimal
  flash_point                 Decimal?          @db.Decimal
  vapour_pressure_min_20c     Decimal?          @db.Decimal
  vapour_pressure_max         Decimal?          @db.Decimal
  tlv_ppm                     Decimal?          @db.Decimal
  liquid_density_at_20c       Decimal?          @db.Decimal
  water_solubility_g_l_at_20c Decimal?          @db.Decimal
  water_solubility_boolean    Decimal?          @db.Decimal
  logp_min                    Decimal?          @db.Decimal
  logp_max                    Decimal?          @db.Decimal
  viscosity_cp_at_20c         Decimal?          @db.Decimal
  notes                       String?
  standard_data_source        String?
  variant                     String?
  formula_hazard              formula_hazard[]
  solvent_formula             solvent_formula[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model formula_hazard {
  formula_id  String
  hazard_id   String
  formula     formula     @relation(fields: [formula_id], references: [formula_id], onDelete: Cascade, onUpdate: NoAction)
  hazard_code hazard_code @relation(fields: [hazard_id], references: [hazard_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([formula_id, hazard_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model hazard_classification {
  classification_id String       @id
  hazard_id         String?
  hazard_class      String?
  category          String?
  signal_word       String?
  hazard_code       hazard_code? @relation(fields: [hazard_id], references: [hazard_id], onDelete: Restrict, onUpdate: Restrict)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model hazard_code {
  hazard_id             String                  @id
  h_code                String?
  hazard_statements     String?
  formula_hazard        formula_hazard[]
  hazard_classification hazard_classification[]
  hazard_pcode          hazard_pcode[]
  solvent_hazard        solvent_hazard[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model hazard_pcode {
  hazard_id   String
  pcode_id    String
  hazard_code hazard_code @relation(fields: [hazard_id], references: [hazard_id], onDelete: Cascade, onUpdate: NoAction)
  p_code      p_code      @relation(fields: [pcode_id], references: [p_code_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hazard_id, pcode_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model observation {
  observation_id String         @id
  solvent_id     String
  property_code  String?
  value          Decimal        @db.Decimal(12, 6)
  unit           String?
  conditions     String?
  reference_id   String?
  notes          String?
  property_type  property_type? @relation(fields: [property_code], references: [property_code], onDelete: Restrict, onUpdate: Restrict)
  reference      reference?     @relation(fields: [reference_id], references: [reference_id], onDelete: Restrict, onUpdate: Restrict)
  solvent        solvent        @relation(fields: [solvent_id], references: [solvent_id], onUpdate: Restrict)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model p_code {
  p_code_id       String            @id
  p_code          String?
  phrase          String
  category        String?
  notes           String?
  hazard_pcode    hazard_pcode[]
  pcode_group_map pcode_group_map[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pcode_group {
  group_id        String            @id
  group_name      String?
  description     String?
  pcode_group_map pcode_group_map[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pcode_group_map {
  group_id    String
  p_code_id   String
  pcode_group pcode_group @relation(fields: [group_id], references: [group_id], onDelete: Cascade, onUpdate: NoAction)
  p_code      p_code      @relation(fields: [p_code_id], references: [p_code_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([group_id, p_code_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model property_type {
  property_code String        @id
  property_name String        @unique
  default_unit  String?
  observation   observation[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reference {
  reference_id      String              @id
  title             String?
  reference_type    String?
  url               String?
  publisher         String?
  jurisdiction      String?
  version           String?
  published_date    DateTime?           @db.Date
  alias_reference   alias_reference[]
  observation       observation[]
  solvent_reference solvent_reference[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model solvent {
  solvent_id        String              @id
  canonical_name    String?
  cas_number        String?
  refchem_id        String?
  is_mixture        Boolean?            @default(false)
  note              String?
  is_deleted        Boolean?            @default(false)
  deleted_at        DateTime?           @db.Timestamp(6)
  alias             alias[]
  observation       observation[]
  solvent_formula   solvent_formula[]
  solvent_hazard    solvent_hazard[]
  solvent_reference solvent_reference[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model solvent_formula {
  solvent_id String
  formula_id String
  fraction   Decimal? @db.Decimal
  formula    formula  @relation(fields: [formula_id], references: [formula_id], onUpdate: Restrict)
  solvent    solvent  @relation(fields: [solvent_id], references: [solvent_id], onDelete: Cascade, onUpdate: Restrict)

  @@id([solvent_id, formula_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model solvent_hazard {
  solvent_id  String
  hazard_id   String
  hazard_code hazard_code @relation(fields: [hazard_id], references: [hazard_id], onDelete: Cascade, onUpdate: NoAction)
  solvent     solvent     @relation(fields: [solvent_id], references: [solvent_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([solvent_id, hazard_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model solvent_reference {
  solvent_id   String
  reference_id String
  reference    reference @relation(fields: [reference_id], references: [reference_id], onDelete: Cascade, onUpdate: NoAction)
  solvent      solvent   @relation(fields: [solvent_id], references: [solvent_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([solvent_id, reference_id])
}