{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["supabase/functions/lib/**/*", "supabase/**/*", "*.ts", "*.js", "scripts/fix_names.js", "scripts/generate_handlers.js", "scripts/generate.js"],
  "exclude": ["node_modules", ".vscode-server", "dist", "**/*.spec.ts", "**/*.test.ts"]
}